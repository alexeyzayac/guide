# Игнорировать директорию .vagrant/ — в ней хранится состояние ВМ, ключи, временные файлы
.vagrant/

# Локальный файл для переопределения настроек Vagrant (если используете)
.Vagrantfile.local

# Логи (если создаются)
*.log

# Временные файлы редакторов
*.swp
*.swo
*~

# Дополнительно: если вы используете Ansible, можно игнорировать retry-файлы
*.retry


.obsidian

#terraform
.terraform
.terraform.lock.hcl
.terraform.tfstate.lock.info
terraform.tfstate
terraform.tfstate.backup

#ansible
inventory.ini